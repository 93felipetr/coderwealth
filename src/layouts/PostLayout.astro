---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: 'security' | 'offgrid' | 'finance';
  tags?: string[];
  image?: string;
  canonicalURL?: URL;
}

const {
  title,
  description,
  pubDate,
  category,
  tags = [],
  image,
  canonicalURL
} = Astro.props;

const categoryLabels = {
  security: 'Security',
  offgrid: 'Offgrid & DIY',
  finance: 'Finance'
};

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout
  title={title}
  description={description}
  image={image || undefined}
  canonicalURL={canonicalURL}
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Article Header -->
    <header class="mb-8">
      <div class="flex items-center space-x-2 mb-4">
        <span class={`inline-flex items-center px-3 py-1 rounded-full text-sm font-medium ${
          category === 'security' ? 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200' :
          category === 'offgrid' ? 'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200' :
          'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200'
        }`}>
          {categoryLabels[category]}
        </span>
        {tags.map(tag => (
          <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-200">
            #{tag}
          </span>
        ))}
      </div>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4 leading-tight">
        {title}
      </h1>

      <p class="text-xl text-gray-300 mb-6 leading-relaxed">
        {description}
      </p>

      <div class="flex items-center text-sm text-gray-400">
        <time datetime={pubDate.toISOString()} class="flex items-center">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          {formattedDate}
        </time>
        <span class="mx-2">•</span>
        <span class="flex items-center">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
          </svg>
          Reading: ~{Math.ceil(description.length / 200)} min
        </span>
      </div>
    </header>

    <!-- Article Content -->
    <div class="prose prose-lg prose-invert max-w-none">
      <slot />
    </div>

    <!-- Article Footer -->
    <footer class="mt-12 pt-8 border-t border-gray-800">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center space-y-4 sm:space-y-0">
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm bg-gray-800 text-gray-300 hover:bg-gray-700 transition-colors cursor-pointer">
              #{tag}
            </span>
          ))}
        </div>
        <div class="flex space-x-4">
          <button class="flex items-center space-x-2 text-gray-400 hover:text-primary-400 transition-colors" title="Share">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z"></path>
            </svg>
            <span class="text-sm">Share</span>
          </button>
        </div>
      </div>

      <!-- Related Articles Navigation -->
      <nav class="mt-8 pt-8 border-t border-gray-800">
        <div class="flex justify-between">
          <a href={`/articles/${category}`} class="flex items-center space-x-2 text-primary-400 hover:text-primary-300 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            <span>More {categoryLabels[category]} articles</span>
          </a>
          <a href="/" class="flex items-center space-x-2 text-primary-400 hover:text-primary-300 transition-colors">
            <span>Back to home</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </nav>
    </footer>
  </article>
</BaseLayout>