---
import type { PostEntry } from '../utils/content-utils';

export interface Props {
  posts: PostEntry[];
  title?: string;
  showCategory?: boolean;
  maxItems?: number;
  className?: string;
}

const {
  posts,
  title,
  showCategory = true,
  maxItems,
  className = ''
} = Astro.props;

const displayPosts = maxItems ? posts.slice(0, maxItems) : posts;

const categoryLabels = {
  security: 'Security',
  offgrid: 'Offgrid & DIY',
  finance: 'Finance'
};

const categoryColors = {
  security: 'bg-red-500',
  offgrid: 'bg-amber-500',
  finance: 'bg-green-500'
};
---

<div class={`space-y-6 ${className}`}>
  {title && (
    <div class="text-center">
      <h2 class="text-3xl font-bold text-white mb-2">{title}</h2>
      <div class="w-24 h-1 bg-primary-500 mx-auto rounded-full"></div>
    </div>
  )}

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {displayPosts.map(post => {
      const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric'
      });

      return (
        <article class="group bg-gray-800/50 backdrop-blur-sm border border-gray-700 rounded-xl overflow-hidden hover:border-primary-500 transition-all duration-300 hover:scale-105 hover:shadow-2xl">
          <!-- Category Badge -->
          {showCategory && (
            <div class="px-4 py-2">
              <span class={`inline-flex items-center px-2 py-1 rounded text-xs font-medium text-white ${categoryColors[post.data.category]}`}>
                {categoryLabels[post.data.category]}
              </span>
            </div>
          )}

          <!-- Content -->
          <div class="p-6">
            <h3 class="text-xl font-bold text-white mb-3 group-hover:text-primary-300 transition-colors line-clamp-2">
              <a href={`/articles/${post.slug}`} class="block">
                {post.data.title}
              </a>
            </h3>

            <p class="text-gray-300 text-sm leading-relaxed mb-4 line-clamp-3">
              {post.data.description}
            </p>

            <!-- Tags -->
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-1 mb-4">
                {post.data.tags.slice(0, 3).map((tag: string) => (
                  <span class="inline-flex items-center px-2 py-1 rounded text-xs bg-gray-700 text-gray-300">
                    #{tag}
                  </span>
                ))}
                {post.data.tags.length > 3 && (
                  <span class="text-xs text-gray-500">
                    +{post.data.tags.length - 3} more
                  </span>
                )}
              </div>
            )}

            <!-- Footer -->
            <div class="flex items-center justify-between text-sm text-gray-400">
              <time datetime={post.data.pubDate.toISOString()} class="flex items-center">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                {formattedDate}
              </time>
              <a
                href={`/articles/${post.slug}`}
                class="flex items-center text-primary-400 hover:text-primary-300 transition-colors font-medium"
              >
                <span class="mr-1">Read more</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>
          </div>
        </article>
      );
    })}
  </div>

  <!-- Load More / View All -->
  {maxItems && posts.length > maxItems && (
    <div class="text-center">
        <a
          href="/artigos"
          class="inline-flex items-center px-6 py-3 bg-primary-600 hover:bg-primary-500 text-white font-medium rounded-lg transition-colors duration-200"
        >
          <span>View all articles</span>
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
    </div>
  )}
</div>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>