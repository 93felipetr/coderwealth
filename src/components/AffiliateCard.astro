---
export interface Props {
  title: string;
  description: string;
  affiliateUrl: string;
  imageUrl?: string;
  category: 'security' | 'offgrid' | 'finance';
  features?: string[];
  ctaText?: string;
  className?: string;
}

const {
  title,
  description,
  affiliateUrl,
  imageUrl = '/assets/placeholder.png',
  category,
  features = [],
  ctaText = 'Learn More',
  className = ''
} = Astro.props;

const categoryColors = {
  security: 'border-red-500 bg-red-500/10 hover:bg-red-500/20',
  offgrid: 'border-amber-500 bg-amber-500/10 hover:bg-amber-500/20',
  finance: 'border-green-500 bg-green-500/10 hover:bg-green-500/20'
};

const categoryTextColors = {
  security: 'text-red-400',
  offgrid: 'text-amber-400',
  finance: 'text-green-400'
};
---

<div class={`group relative bg-gray-800/50 backdrop-blur-sm border ${categoryColors[category]} rounded-xl p-6 transition-all duration-300 hover:scale-105 hover:shadow-2xl ${className}`}>
  <!-- Affiliate Badge -->
  <div class="absolute top-4 right-4">
    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-accent-500 text-black">
      Parceiro
    </span>
  </div>

  <!-- Content -->
  <div class="space-y-4">
    <!-- Image/Icon -->
    <div class="w-16 h-16 bg-gray-700 rounded-lg flex items-center justify-center group-hover:bg-gray-600 transition-colors">
      {imageUrl !== '/assets/placeholder.png' ? (
        <img
          src={imageUrl}
          alt={title}
          class="w-12 h-12 object-contain"
          loading="lazy"
        />
      ) : (
        <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
        </svg>
      )}
    </div>

    <!-- Title and Description -->
    <div>
      <h3 class="text-xl font-bold text-white mb-2 group-hover:text-primary-300 transition-colors">
        {title}
      </h3>
      <p class="text-gray-300 text-sm leading-relaxed">
        {description}
      </p>
    </div>

    <!-- Features -->
    {features.length > 0 && (
      <ul class="space-y-1">
        {features.map(feature => (
          <li class="flex items-center text-sm text-gray-400">
            <svg class="w-4 h-4 mr-2 text-green-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            {feature}
          </li>
        ))}
      </ul>
    )}

    <!-- CTA Button -->
    <a
      href={affiliateUrl}
      target="_blank"
      rel="noopener noreferrer sponsored"
      class={`inline-flex items-center justify-center w-full px-4 py-3 rounded-lg font-medium transition-all duration-200 group-hover:scale-105 ${categoryTextColors[category]} bg-transparent border border-current hover:bg-current hover:text-black`}
    >
      <span class="mr-2">{ctaText}</span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
      </svg>
    </a>
  </div>

  <!-- Hover Effect Overlay -->
  <div class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none">
    <div class={`absolute inset-0 rounded-xl ${categoryColors[category]} opacity-5`}></div>
  </div>
</div>