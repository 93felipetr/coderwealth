---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostGrid from '../../../components/PostGrid.astro';
import LeadCaptureForm from '../../../components/LeadCaptureForm.astro';
import { getPostsByCategory, getCategoryInfo } from '../../../utils/content-utils';

export async function getStaticPaths() {
  return [
    { params: { category: 'security' } },
    { params: { category: 'offgrid' } },
    { params: { category: 'finance' } }
  ];
}

const { category } = Astro.params;
const categoryInfo = getCategoryInfo(category as 'security' | 'offgrid' | 'finance')!;
const posts = await getPostsByCategory(category as 'security' | 'offgrid' | 'finance');

// Get posts for other categories (for the related section)
const otherCategories: ('security' | 'offgrid' | 'finance')[] = (category === 'security' ? ['offgrid', 'finance'] :
  category === 'offgrid' ? ['security', 'finance'] :
  ['security', 'offgrid']);

const relatedCategoriesData = await Promise.all(
  otherCategories.map(async (cat) => ({
    category: cat,
    info: getCategoryInfo(cat as 'security' | 'offgrid' | 'finance'),
    posts: await getPostsByCategory(cat as 'security' | 'offgrid' | 'finance')
  }))
);
---

<BaseLayout
  title={`${categoryInfo.label} - CoderWealth`}
  description={`Articles about ${categoryInfo.description.toLowerCase()}. Premium technical content about ${categoryInfo.label.toLowerCase()}.`}
>
  <!-- Hero Section -->
  <section class="relative py-20 bg-gradient-to-br from-gray-900 via-gray-800 to-primary-900/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <div class={`inline-flex items-center px-4 py-2 rounded-full text-sm font-medium mb-6 ${
          category === 'security' ? 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200' :
          category === 'offgrid' ? 'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200' :
          'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200'
        }`}>
          {categoryInfo.label}
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">
          Artigos sobre <span class={`${
            category === 'security' ? 'text-red-400' :
              category === 'offgrid' ? 'text-amber-400' :
            'text-green-400'
          }`}>{categoryInfo!.label}</span>
        </h1>

        <p class="text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
          {categoryInfo!.description}
        </p>

        <div class="mt-8 text-sm text-gray-400">
          <span class="inline-flex items-center px-3 py-1 rounded-full bg-gray-800">
            {posts.length} artigo{posts.length !== 1 ? 's' : ''} publicado{posts.length !== 1 ? 's' : ''}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Articles Section -->
  <section class="py-20 bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length > 0 ? (
        <PostGrid posts={posts} />
      ) : (
        <div class="text-center py-20">
          <div class={`w-24 h-24 ${
              category === 'security' ? 'bg-red-500/20' :
              category === 'offgrid' ? 'bg-amber-500/20' :
            'bg-green-500/20'
          } rounded-full flex items-center justify-center mx-auto mb-8`}>
            <svg class={`w-12 h-12 ${
              category === 'security' ? 'text-red-400' :
            category === 'offgrid' ? 'text-amber-400' :
              'text-green-400'
            }`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>

          <h2 class="text-2xl font-bold text-white mb-4">
            Articles Coming Soon
          </h2>
          <p class="text-gray-300 mb-8 max-w-2xl mx-auto">
            We are working on premium content about {categoryInfo!.label.toLowerCase()}.
            Be the first to know when new articles are published.
          </p>

          <div class="max-w-md mx-auto">
            <LeadCaptureForm
              title={`Stay Updated`}
              subtitle={`Receive notifications when new articles about ${categoryInfo!.label.toLowerCase()} are published.`}
              buttonText="Notify me"
              className="bg-white/10 border-primary-600"
            />
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Related Categories -->
  <section class="py-16 bg-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl font-bold text-white mb-4">
          Explore Other Categories
        </h2>
        <p class="text-gray-300">
          Comprehensive technical content about technology and finance
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {relatedCategoriesData.map(({ category: otherCategory, info: otherInfo, posts: otherPosts }) => (
          <a
            href={`/articles/${otherCategory}`}
            class={`group block p-6 rounded-xl border transition-all duration-300 hover:scale-105 ${
              otherCategory === 'security' ? 'border-red-500/20 bg-red-500/5 hover:bg-red-500/10' :
              otherCategory === 'offgrid' ? 'border-amber-500/20 bg-amber-500/5 hover:bg-amber-500/10' :
              'border-green-500/20 bg-green-500/5 hover:bg-green-500/10'
            }`}
          >
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-lg font-semibold text-white group-hover:text-primary-300 transition-colors">
                {otherInfo.label}
              </h3>
              <span class="text-sm text-gray-400">
                {otherPosts.length} artigo{otherPosts.length !== 1 ? 's' : ''}
              </span>
            </div>
            <p class="text-gray-300 text-sm leading-relaxed">
              {otherInfo.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>